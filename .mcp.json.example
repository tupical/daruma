{
  "_comment": "Generate a token and download daruma-mcp from the web UI: Settings (gear icon) → MCP section. Copy the snippet from there — do not commit real tokens.",
  "_binary": "Download daruma-mcp for your OS from Settings, not from this repo. Point command at the saved binary path.",
  "_local_state": "MCP client writes ~/.agents/daruma/workspaces.json (see docs/guides/mcp-client.md). Optional: DARUMA_WORKSPACE, DARUMA_AGENT_DIR.",

  "mcpServers": {
    "daruma": {
      "type": "stdio",
      "command": "C:\\Tools\\daruma-mcp.exe",
      "args": [],
      "env": {
        "DARUMA_API_URL": "http://localhost:8080",
        "DARUMA_TOKEN": "ta_svc_…",
