{
  "name": "taskagent-cursor-extension",
  "version": "0.1.0",
  "description": "Native Cursor/VSCode sidebar for TaskAgent projects, plans, and tasks.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tupical/taskagent.git",
    "directory": "clients/cursor-extension"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:taskagent.tasks",
    "onCommand:taskagent.refresh"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskagent",
          "title": "TaskAgent",
          "icon": "media/taskagent.svg"
        }
      ]
    },
    "views": {
      "taskagent": [
        {
          "id": "taskagent.tasks",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "taskagent.refresh",
        "title": "TaskAgent: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "taskagent.completeTask",
        "title": "TaskAgent: Complete Task",
        "icon": "$(pass)"
      },
      {
        "command": "taskagent.claimTask",
        "title": "TaskAgent: Claim Task",
        "icon": "$(account)"
      },
      {
        "command": "taskagent.commentTask",
        "title": "TaskAgent: Comment on Task",
        "icon": "$(comment)"
      },
      {
        "command": "taskagent.setTaskPriority",
        "title": "TaskAgent: Set Task Priority",
        "icon": "$(symbol-number)"
      },
      {
        "command": "taskagent.splitTask",
        "title": "TaskAgent: Split Task",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "taskagent.showTask",
        "title": "TaskAgent: Show Task"
      },
      {
        "command": "taskagent.openPlan",
        "title": "TaskAgent: Open Plan",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskagent.refresh",
          "when": "view == taskagent.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "taskagent.openPlan",
          "when": "view == taskagent.tasks && viewItem == taskagent.plan",
          "group": "inline"
        },
        {
          "command": "taskagent.completeTask",
          "when": "view == taskagent.tasks && viewItem == taskagent.task",
          "group": "inline@1"
        },
        {
          "command": "taskagent.claimTask",
          "when": "view == taskagent.tasks && viewItem == taskagent.task",
          "group": "inline@2"
        },
        {
          "command": "taskagent.commentTask",
          "when": "view == taskagent.tasks && viewItem == taskagent.task",
          "group": "inline@3"
        },
        {
          "command": "taskagent.setTaskPriority",
          "when": "view == taskagent.tasks && viewItem == taskagent.task",
          "group": "1_actions@1"
        },
        {
          "command": "taskagent.splitTask",
          "when": "view == taskagent.tasks && viewItem == taskagent.task",
          "group": "1_actions@2"
        }
      ]
    },
    "configuration": {
      "title": "TaskAgent",
      "properties": {
        "taskagent.apiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "TaskAgent server base URL."
        },
        "taskagent.token": {
          "type": "string",
          "default": "",
          "description": "TaskAgent bearer token."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "test": "npm run compile && node --test tests/**/*.test.mjs",
    "package": "npx --yes @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.0"
  }
}
